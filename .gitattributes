# Enforce LF endings for Python code
*.py text eol=lf

# Common text files should use LF
*.txt text eol=lf
*.md  text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Auto-detect line endings for other text files
* text=auto

# Keep binary files untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.exe binary
